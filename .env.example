# =============================================================================
# Copy to `.env` and fill in. Never commit `.env`.
# Rebuild the app (`npm run build` / restart `npm run dev`) after changes—Vite
# bakes `VITE_*` values at build/start time.
# =============================================================================

# --- Supabase (required for the app) ---
# Dashboard → Project Settings → API
VITE_SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Owner account email (used to show owner-only Invite User button)
VITE_OWNER_EMAIL=owner@example.com

# --- Writing audit → GitHub (optional) ---
# Set to the string `true` only after you have deployed the Edge Function
# `append-writing-log` and configured GitHub + Supabase secrets (see comments below).
# Any other value or omitting this variable disables audit calls (safe default).
VITE_WRITING_AUDIT_ENABLED=false

# =============================================================================
# NOT in this file — set on Supabase (Edge Function secrets), not in Vite .env
# =============================================================================
# Deploy: `supabase functions deploy append-writing-log`
# Then:    `supabase secrets set KEY=value ...`
#
# Required for owner invite flow (Edge Function: invite-user):
#   OWNER_EMAIL          — owner account email allowed to create users
#
# Required for owner delete flow (Edge Function: delete-user):
#   OWNER_EMAIL          — same owner email used above
#
# Required for audit:
#   GITHUB_TOKEN         — repo Contents read/write (fine-grained or classic PAT)
#   GITHUB_OWNER         — GitHub username or org that owns the audit repo
#   GITHUB_REPO          — repo name only (e.g. writing-audit-log)
#
# Optional:
#   GITHUB_FILE_PATH     — default writing_audit.csv (can be e.g. logs/audit.csv)
#   GITHUB_BRANCH        — default main
#
# Usually auto-injected on hosted Supabase (do not set manually unless docs say so):
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#
# For local `supabase functions serve`, use `supabase/.env` per Supabase CLI docs.
# =============================================================================
